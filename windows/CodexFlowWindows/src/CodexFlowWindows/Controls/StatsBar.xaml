<UserControl
    x:Class="CodexFlowWindows.Controls.StatsBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" CornerRadius="8" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="4">
                <TextBlock Text="总会话" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="TotalText" Text="0" FontSize="24" FontWeight="SemiBold" />
            </StackPanel>
        </Border>
        <Border Grid.Column="1" CornerRadius="8" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="4">
                <TextBlock Text="已加载" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="LoadedText" Text="0" FontSize="24" FontWeight="SemiBold" />
            </StackPanel>
        </Border>
        <Border Grid.Column="2" CornerRadius="8" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="4">
                <TextBlock Text="运行中" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="ActiveText" Text="0" FontSize="24" FontWeight="SemiBold" />
            </StackPanel>
        </Border>
        <Border Grid.Column="3" CornerRadius="8" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="4">
                <TextBlock Text="待审批" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="ApprovalsText" Text="0" FontSize="24" FontWeight="SemiBold" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
