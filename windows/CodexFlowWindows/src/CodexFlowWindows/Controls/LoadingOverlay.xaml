<UserControl
    x:Class="CodexFlowWindows.Controls.LoadingOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">
    <Grid Background="#66000000">
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ProgressRing IsActive="True" Width="22" Height="22" />
                <TextBlock Text="正在处理..." VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
