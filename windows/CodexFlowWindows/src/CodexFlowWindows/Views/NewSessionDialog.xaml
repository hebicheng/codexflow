<ContentDialog
    x:Class="CodexFlowWindows.Views.NewSessionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="新建受控会话"
    PrimaryButtonText="创建"
    CloseButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonClick="PrimaryClicked">
    <StackPanel Spacing="12" MinWidth="520">
        <TextBox
            Header="工作目录"
            Text="{Binding Cwd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            PlaceholderText="/Users/me/repo 或 C:\work\repo"
            FontFamily="Consolas" />
        <TextBox
            Header="首轮 prompt"
            Text="{Binding Prompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            AcceptsReturn="True"
            MinHeight="140"
            TextWrapping="Wrap"
            PlaceholderText="例如：继续实现剩余部分，并补上验证。" />
        <InfoBar IsOpen="True" IsClosable="False" Severity="Error" Message="{Binding ErrorMessage}" />
    </StackPanel>
</ContentDialog>
